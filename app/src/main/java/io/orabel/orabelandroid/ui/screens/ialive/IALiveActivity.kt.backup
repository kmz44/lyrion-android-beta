class IALiveActivity : ComponentActivity(), RecognitionListener {

    // Dependencias
    private val chatsDB: ChatsDB by inject()
    private val messagesDB: MessagesDB by inject()
    private val modelsRepository: ModelsRepository by inject()
    private val ttsRepository: TtsRepository by inject()
    
    // Estados principales
    private var currentState by mutableStateOf(IALiveState.IDLE)
    private var displayText by mutableStateOf("")
    private var conversationHistory by mutableStateOf(listOf<ConversationMessage>())
    
    // Estados de componentes
    private var isListening by mutableStateOf(false)
    private var isProcessingLLM by mutableStateOf(false)
    private var isSpeaking by mutableStateOf(false)
    
    // Modelos y servicios
    private var voskModel: Model? = null
    
    // NUEVO: Variables para reconocimiento MANUAL (sin callbacks automáticos)
    private var voskRecognizer: org.vosk.Recognizer? = null
    private var audioRecord: android.media.AudioRecord? = null
    private var recordingThread: Thread? = null
    private var isManualRecording = false
    private var finalRecognizedText = ""
    
    private var currentChat: Chat? = null
    private var currentLLMModel: LLMModel? = null
    private var mediaRecorder: MediaRecorder? = null
    private var orabeLLMInstance: Orabel? = null // Instancia para el modelo LLM
    
    // Control de flujo
    private var llmGenerationJob: Job? = null
    private var partialLLMResponse by mutableStateOf("")
    
    // Permisos
    private val permissionsLauncher = registerForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) { permissions ->
        Log.d("IALive", "Permisos recibidos: $permissions")
        
        // Solo verificar el permiso crítico: RECORD_AUDIO
        val audioPermissionGranted = permissions[Manifest.permission.RECORD_AUDIO] == true
        
        if (audioPermissionGranted) {
            Log.d("IALive", "Permiso de audio concedido, inicializando componentes...")
            initializeComponents()
        } else {
            SafeToast.showSafe(this, "Se requiere permiso de micrófono para IA Live")
            finish()
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        
        checkAndRequestPermissions()
        
        setContent {
            ModernOrabelTheme {
                IALiveScreen(
                    state = currentState,
                    displayText = displayText,
                    conversationHistory = conversationHistory,
                    isListening = isListening,
                    isProcessingLLM = isProcessingLLM,
                    isSpeaking = isSpeaking,
                    onStartListening = { startListeningOnPress() },
                    onStopListening = { stopListeningOnRelease() },
                    onStopAll = { stopAllProcesses() },
                    onBackClick = { finish() },
                    onSelectModel = { showModelSelection() }
                )
            }
        }
    }

    private fun checkAndRequestPermissions() {
        Log.d("IALive", "Verificando permisos...")
        
        // Solo solicitar permisos críticos
        val criticalPermissions = arrayOf(
            Manifest.permission.RECORD_AUDIO
        )
        
        val notGranted = criticalPermissions.filter {
            val granted = ContextCompat.checkSelfPermission(this, it) == PackageManager.PERMISSION_GRANTED
            Log.d("IALive", "Permiso $it: ${if (granted) "CONCEDIDO" else "NO CONCEDIDO"}")
            !granted
        }
        
        if (notGranted.isEmpty()) {
            Log.d("IALive", "Todos los permisos críticos concedidos, inicializando...")
            initializeComponents()
        } else {
            Log.d("IALive", "Solicitando permisos: $notGranted")
            permissionsLauncher.launch(criticalPermissions)
        }
    }

    private fun initializeComponents() {
        CoroutineScope(Dispatchers.IO).launch {
            try {
                withContext(Dispatchers.Main) {
                    currentState = IALiveState.INITIALIZING
                    displayText = "🔧 Inicializando componentes..."
                }

                // 1. Inicializar Vosk para STT
                initializeVosk()
                
                // 2. Cargar chat por defecto y modelo LLM
                initializeLLM()
                
                // 3. Inicializar TTS
                initializeTTS()
                
                withContext(Dispatchers.Main) {
                    currentState = IALiveState.READY
                    displayText = "✅ IA Live listo\n\nPresiona el botón para comenzar una conversación"
                }
                
            } catch (e: Exception) {
                withContext(Dispatchers.Main) {
                    currentState = IALiveState.ERROR
                    displayText = "❌ Error inicializando: ${e.message}"
                }
            }
        }
    }

    private suspend fun initializeVosk() {
        withContext(Dispatchers.Main) {
            displayText = "📱 Configurando reconocimiento de voz..."
        }
        
        val modelName = "vosk-model-small-es-0.42"
        StorageService.unpack(
            this@IALiveActivity, 
            modelName, 
            "model",
            { model ->
                voskModel = model
            },
            { exception ->
                throw exception
            }
        )
    }

    private suspend fun initializeLLM() {
        withContext(Dispatchers.Main) {
            displayText = "🧠 Configurando modelo de lenguaje..."
        }
        
        // Obtener chat por defecto
        currentChat = chatsDB.loadDefaultChat(this@IALiveActivity)
        
        // Cargar historial de mensajes existente
        val existingMessages = messagesDB.getMessagesForModel(currentChat!!.id)
        conversationHistory = existingMessages.map { message ->
            ConversationMessage(
                text = message.message,
                isUser = message.isUserMessage,
                timestamp = System.currentTimeMillis()
            )
        }
        
        withContext(Dispatchers.Main) {
            displayText = if (conversationHistory.isNotEmpty()) {
                "📜 Historial cargado (${conversationHistory.size} mensajes)\n\nPresiona para continuar la conversación"
            } else {
                "📜 Nueva conversación iniciada\n\nPresiona para comenzar"
            }
        }
        
        // Verificar si hay modelo configurado
        if (currentChat?.llmModelId == -1L) {
            // Necesitamos seleccionar un modelo
            val availableModels = modelsRepository.getAvailableModelsList()
            if (availableModels.isNotEmpty()) {
                currentLLMModel = availableModels.first()
                currentChat = currentChat?.copy(llmModelId = currentLLMModel!!.id)
                chatsDB.updateChat(currentChat!!)
            } else {
                throw Exception("No hay modelos LLM disponibles. Configura un modelo primero.")
            }
        } else {
            currentLLMModel = modelsRepository.getModelFromId(currentChat!!.llmModelId)
        }
        
        // Cargar el modelo en Orabel
        currentLLMModel?.let { model ->
            val modelFile = File(model.path)
            if (!modelFile.exists()) {
                throw Exception("Archivo del modelo no encontrado: ${model.path}")
            }
            
            orabeLLMInstance = Orabel()
            orabeLLMInstance!!.create(
                model.path,
                currentChat!!.minP,
                currentChat!!.temperature,
                true
            )
            
            // Añadir system prompt si existe
            if (currentChat!!.systemPrompt.isNotEmpty()) {
                orabeLLMInstance!!.addSystemPrompt(currentChat!!.systemPrompt)
            }
        }
    }

    private suspend fun initializeTTS() {
        withContext(Dispatchers.Main) {
            displayText = "🔊 Configurando síntesis de voz..."
        }
        
        val success = ttsRepository.initializeTts()
        if (!success) {
            throw Exception("Error inicializando TTS")
        }
        
        val spanishSet = ttsRepository.setSpanishLanguage()
        if (!spanishSet) {
            throw Exception("No se pudo configurar español para TTS")
        }
    }

    private fun startConversation() {
        if (currentState != IALiveState.READY) return
        
        currentState = IALiveState.LISTENING
        isListening = true
        displayText = "🎤 Toca INICIAR para empezar a grabar..."
        
        startManualVoiceRecording()
        startAudioRecording() // Para guardar el audio
    }
    
    // Nueva función para cuando se presiona el botón
    private fun startListeningOnPress() {
        if (currentState != IALiveState.READY) return
        
        Log.d("IALive", "Iniciando escucha al presionar botón")
        
        // Limpiar texto previo
        finalRecognizedText = ""
        
        currentState = IALiveState.LISTENING
        isListening = true
        displayText = "🎤 Escuchando... Habla normalmente"
        
        startManualVoiceRecording()
        startAudioRecording()
    }
    
    // Nueva función para cuando se suelta el botón - COMPLETAMENTE MANUAL
    private fun stopListeningOnRelease() {
        if (!isListening) return
        
        Log.d("IALive", "Deteniendo escucha - obteniendo texto final MANUAL")
        
        // Cambiar estado inmediatamente
        currentState = IALiveState.PROCESSING_STT
        displayText = "⏳ Procesando tu mensaje..."
        
        // Usar el sistema manual sin callbacks
        stopManualVoiceRecording()
    }
    
    // Función para obtener el texto final directamente del recognizer
    private fun getFinalTextFromRecognizer(): String {
        return try {
            // Esta función ya no se usa - ahora usamos sistema manual
            return finalRecognizedText.takeIf { it.isNotEmpty() } ?: ""
        } catch (e: Exception) {
            Log.e("IALive", "Error obteniendo texto del recognizer: ${e.message}")
            return ""
        }
    }

    // NUEVA FUNCIÓN: Iniciar grabación MANUAL sin callbacks automáticos
    private fun startManualVoiceRecording() {
        voskModel?.let { model ->
            try {
                Log.d("IALive", "Iniciando reconocimiento MANUAL")
                
                // Crear el reconocedor Vosk
                voskRecognizer = org.vosk.Recognizer(model, 16000.0f)
                finalRecognizedText = ""
                
                // Configurar AudioRecord para capturar audio
                val minBufferSize = AudioRecord.getMinBufferSize(
                    16000,
                    AudioFormat.CHANNEL_IN_MONO,
                    AudioFormat.ENCODING_PCM_16BIT
                )
                
                audioRecord = AudioRecord(
                    AudioSource.MIC,
                    16000,
                    AudioFormat.CHANNEL_IN_MONO,
                    AudioFormat.ENCODING_PCM_16BIT,
                    minBufferSize
                )
                
                isManualRecording = true
                audioRecord?.startRecording()
                
                // Crear hilo para procesar audio
                recordingThread = Thread {
                    val buffer = ShortArray(minBufferSize)
                    
                    while (isManualRecording && audioRecord != null) {
                        val bytesRead = audioRecord!!.read(buffer, 0, buffer.size)
                        if (bytesRead > 0) {
                            // Convertir a bytes para Vosk
                            val audioData = ByteArray(bytesRead * 2)
                            for (i in 0 until bytesRead) {
                                audioData[i * 2] = (buffer[i].toInt() and 0xFF).toByte()
                                audioData[i * 2 + 1] = (buffer[i].toInt() shr 8 and 0xFF).toByte()
                            }
                            
                            // Procesar con Vosk MANUALMENTE
                            voskRecognizer?.let { recognizer ->
                                if (recognizer.acceptWaveForm(audioData, audioData.size)) {
                                    val result = recognizer.result
                                    val extractedText = extractTextFromVoskJson(result)
                                    if (extractedText.trim().isNotEmpty()) {
                                        finalRecognizedText = extractedText.trim()
                                        
                                        // Actualizar UI en el hilo principal
                                        runOnUiThread {
                                            displayText = "🎤 Escuchando...\n\n\"$finalRecognizedText\""
                                        }
                                    }
                                } else {
                                    // Resultado parcial
                                    val partialResult = recognizer.partialResult
                                    val extractedText = extractTextFromVoskJson(partialResult)
                                    if (extractedText.trim().isNotEmpty()) {
                                        runOnUiThread {
                                            displayText = "🎤 Escuchando...\n\n\"$extractedText\""
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                recordingThread?.start()
                
            } catch (e: Exception) {
                Log.e("IALive", "Error iniciando grabación manual: ${e.message}")
                currentState = IALiveState.ERROR
                displayText = "❌ Error iniciando reconocimiento: ${e.message}"
            }
        }
    }

    private fun startAudioRecording() {
        try {
            val fileName = "ia_live_${System.currentTimeMillis()}.m4a"
            val downloadsDir = File(
                Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOWNLOADS),
                "LyrionVozTexto"
            )
            
            if (!downloadsDir.exists()) {
                downloadsDir.mkdirs()
            }
            
            val audioFile = File(downloadsDir, fileName)
            
            mediaRecorder = MediaRecorder().apply {
                setAudioSource(MediaRecorder.AudioSource.MIC)
                setOutputFormat(MediaRecorder.OutputFormat.MPEG_4)
                setAudioEncoder(MediaRecorder.AudioEncoder.AAC)
                setOutputFile(audioFile.absolutePath)
                prepare()
                start()
            }
            
        } catch (e: Exception) {
            Log.e("IALive", "Error iniciando grabación de audio: ${e.message}")
        }
    }

    // NUEVA FUNCIÓN: Parar grabación MANUAL sin callbacks automáticos
    private fun stopManualVoiceRecording() {
        try {
            Log.d("IALive", "Parando reconocimiento MANUAL")
            
            isManualRecording = false
            
            // Parar AudioRecord
            audioRecord?.apply {
                if (recordingState == AudioRecord.RECORDSTATE_RECORDING) {
                    stop()
                }
                release()
            }
            audioRecord = null
            
            // Esperar que termine el hilo
            recordingThread?.join(1000)
            recordingThread = null
            
            // Obtener resultado final del reconocedor
            voskRecognizer?.let { recognizer ->
                val finalResult = recognizer.finalResult
                val extractedText = extractTextFromVoskJson(finalResult)
                if (extractedText.trim().isNotEmpty()) {
                    finalRecognizedText = extractedText.trim()
                }
                recognizer.close()
            }
            voskRecognizer = null
            
            Log.d("IALive", "Texto final reconocido: '$finalRecognizedText'")
            
            // Procesar el texto reconocido SI HAY CONTENIDO
            if (finalRecognizedText.trim().isNotEmpty()) {
                processRecognizedText(finalRecognizedText.trim())
            } else {
                displayText = "🎤 No se reconoció ningún texto. Toca INICIAR para intentar de nuevo."
                currentState = IALiveState.LISTENING
            }
            
        } catch (e: Exception) {
            Log.e("IALive", "Error parando grabación manual: ${e.message}")
            displayText = "❌ Error parando reconocimiento: ${e.message}"
            currentState = IALiveState.ERROR
        }
    // NUEVA FUNCIÓN: Procesar texto reconocido sin usar callbacks automáticos
    private fun processRecognizedText(text: String) {
        Log.d("IALive", "Procesando texto manual: '$text'")
        
        // Parar también la grabación de audio
        stopAudioRecording()
        
        // Procesar directamente con el LLM
        processWithLLM(text)
    }
    
    private fun stopAudioRecording() {
        isListening = false
        
        // Detener grabación de audio
        try {
            mediaRecorder?.apply {
                stop()
                reset()
                release()
            }
            mediaRecorder = null
        } catch (e: Exception) {
            Log.e("IALive", "Error deteniendo grabación: ${e.message}")
        }
    }

    private fun processWithLLM(userMessage: String) {
        currentState = IALiveState.PROCESSING_LLM
        isProcessingLLM = true
        displayText = "🧠 Procesando con IA..."
        
        // Añadir mensaje del usuario a la conversación
        conversationHistory = conversationHistory + ConversationMessage(
            text = userMessage,
            isUser = true,
            timestamp = System.currentTimeMillis()
        )
        
        // Guardar mensaje en base de datos
        currentChat?.let { chat ->
            messagesDB.addUserMessage(chat.id, userMessage)
        }
        
        llmGenerationJob = CoroutineScope(Dispatchers.Default).launch {
            try {
                partialLLMResponse = ""
                var fullResponse = ""
                var lastResponse = ""
                
                orabeLLMInstance?.getResponse(userMessage)?.collectLatest { partialResponse ->
                    partialLLMResponse += partialResponse
                    fullResponse = partialLLMResponse
                    lastResponse = fullResponse // Mantener siempre la última respuesta
                    
                    withContext(Dispatchers.Main) {
                        displayText = "🧠 IA respondiendo...\n\n$fullResponse"
                    }
                }
                
                // Respuesta completa generada O detenida
                orabeLLMInstance?.stopCompletion()
                
                withContext(Dispatchers.Main) {
                    // Usar la última respuesta disponible, aunque esté incompleta
                    val finalResponse = if (lastResponse.trim().isNotEmpty()) {
                        lastResponse
                    } else if (fullResponse.trim().isNotEmpty()) {
                        fullResponse
                    } else {
                        "Lo siento, no pude generar una respuesta completa."
                    }
                    
                    Log.d("IALive", "Respuesta final para TTS: $finalResponse")
                    
                    // Añadir respuesta a la conversación
                    conversationHistory = conversationHistory + ConversationMessage(
                        text = finalResponse,
                        isUser = false,
                        timestamp = System.currentTimeMillis()
                    )
                    
                    // Guardar en base de datos
                    currentChat?.let { chat ->
                        messagesDB.addAssistantMessage(chat.id, finalResponse)
                    }
                    
                    isProcessingLLM = false
                    
                    // SIEMPRE proceder con TTS, incluso si la respuesta está incompleta
                    speakResponse(finalResponse)
                }
                
            } catch (e: Exception) {
                Log.e("IALive", "Error en LLM: ${e.message}")
                withContext(Dispatchers.Main) {
                    // Si hay error, pero tenemos respuesta parcial, usarla para TTS
                    if (partialLLMResponse.trim().isNotEmpty()) {
                        Log.d("IALive", "Error en LLM pero hay respuesta parcial, usando para TTS: $partialLLMResponse")
                        
                        conversationHistory = conversationHistory + ConversationMessage(
                            text = partialLLMResponse,
                            isUser = false,
                            timestamp = System.currentTimeMillis()
                        )
                        
                        currentChat?.let { chat ->
                            messagesDB.addAssistantMessage(chat.id, partialLLMResponse)
                        }
                        
                        isProcessingLLM = false
                        speakResponse(partialLLMResponse)
                    } else {
                        // Sin respuesta parcial, mostrar error
                        currentState = IALiveState.ERROR
                        displayText = "❌ Error procesando con LLM: ${e.message}"
                        isProcessingLLM = false
                    }
                }
            }
        }
    }

    private fun speakResponse(response: String) {
        currentState = IALiveState.SPEAKING
        isSpeaking = true
        displayText = "🔊 Reproduciendo respuesta...\n\n$response"
        
        CoroutineScope(Dispatchers.IO).launch {
            try {
                val success = ttsRepository.speak(response)
                withContext(Dispatchers.Main) {
                    if (success) {
                        // TTS completado exitosamente
                        isSpeaking = false
                        currentState = IALiveState.READY
                        displayText = "✅ Conversación completada\n\nPresiona el botón para continuar"
                    } else {
                        // Error en TTS
                        isSpeaking = false
                        currentState = IALiveState.ERROR
                        displayText = "❌ Error en síntesis de voz"
                    }
                }
            } catch (e: Exception) {
                withContext(Dispatchers.Main) {
                    isSpeaking = false
                    currentState = IALiveState.ERROR
                    displayText = "❌ Error en síntesis de voz: ${e.message}"
                }
            }
        }
    }

    private fun stopAllProcesses() {
        // Si está procesando LLM y hay respuesta parcial, proceder con TTS
        if (isProcessingLLM && partialLLMResponse.trim().isNotEmpty()) {
            Log.d("IALive", "Deteniendo LLM pero procediendo con TTS de respuesta parcial: $partialLLMResponse")
            
            llmGenerationJob?.cancel()
            
            try {
                orabeLLMInstance?.cancelCompletion()
            } catch (e: Exception) {
                Log.e("IALive", "Error cancelando LLM: ${e.message}")
            }
            
            // Proceder con TTS de la respuesta parcial
            conversationHistory = conversationHistory + ConversationMessage(
                text = partialLLMResponse,
                isUser = false,
                timestamp = System.currentTimeMillis()
            )
            
            currentChat?.let { chat ->
                messagesDB.addAssistantMessage(chat.id, partialLLMResponse)
            }
            
            isProcessingLLM = false
            speakResponse(partialLLMResponse)
            return
        }
        
        // Detener todos los procesos normalmente
        llmGenerationJob?.cancel()
        
        // Detener STT manual
        stopManualVoiceRecording()
        
        // Detener LLM - solo si está cargado
        try {
            orabeLLMInstance?.cancelCompletion()
        } catch (e: Exception) {
            Log.e("IALive", "Error cancelando LLM: ${e.message}")
        }
        
        // Detener TTS
        ttsRepository.stop()
        
        // Resetear estados
        isListening = false
        isProcessingLLM = false
        isSpeaking = false
        currentState = IALiveState.READY
        displayText = "⏹️ Procesos detenidos\n\nPresiona el botón para comenzar de nuevo"
    }

    private fun showModelSelection() {
        // TODO: Implementar selección de modelo
        SafeToast.showSafe(this, "Función de selección de modelo próximamente")
    }

