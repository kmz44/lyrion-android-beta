    }

    override fun onFinalResult(hypothesis: String?) {
        // NADA - COMPLETAMENTE DESACTIVADO
        // YA NO SE USAN CALLBACKS - AHORA ES MANUAL
        Log.d("IALive", "Callback onFinalResult IGNORADO - usando sistema manual")
    }
    
    // Función para extraer texto del JSON de Vosk - MEJORADA
    private fun extractTextFromVoskJson(jsonString: String): String {
        return try {
            val cleanJson = jsonString.trim()
            
            if (cleanJson.startsWith("{") && cleanJson.contains("\"text\"")) {
                // Es JSON de Vosk, extraer SOLO el campo "text"
                val regex = "\"text\"\\s*:\\s*\"([^\"]*)\""
                val matchResult = Regex(regex).find(cleanJson)
                val extractedText = matchResult?.groupValues?.get(1)?.trim() ?: ""
                
                Log.d("IALive", "JSON original: $cleanJson")
                Log.d("IALive", "Texto extraído: '$extractedText'")
                
                return extractedText
            } else {
                // No es JSON, devolver tal como está (limpio)
                return cleanJson
            }
        } catch (e: Exception) {
            Log.e("IALive", "Error extrayendo texto de JSON: ${e.message}")
            // En caso de error, intentar devolver solo texto plano
            return jsonString.replace(Regex("[{}\":\\[\\],]"), "").trim()
        }
    }

    override fun onError(exception: Exception?) {
        // NADA - COMPLETAMENTE DESACTIVADO
        // YA NO SE USAN CALLBACKS - AHORA ES MANUAL  
        Log.d("IALive", "Callback onError IGNORADO - usando sistema manual")
    }

    override fun onTimeout() {
        // NADA - COMPLETAMENTE DESACTIVADO
        // YA NO SE USAN CALLBACKS - AHORA ES MANUAL
        Log.d("IALive", "Callback onTimeout IGNORADO - usuario controla la duración manualmente")
    }

    override fun onDestroy() {
        super.onDestroy()
        
        stopAllProcesses()
        
        // Liberar recursos del modelo LLM de forma segura
        try {
            orabeLLMInstance?.let { instance ->
                try {
                    instance.cancelCompletion()
                } catch (e: Exception) {
                    Log.w("IALive", "Error cancelando completion: ${e.message}")
                }
                // No llamar close() - causa crash
                orabeLLMInstance = null
            }
        } catch (e: Exception) {
            Log.e("IALive", "Error liberando Orabel: ${e.message}")
        }
        
        ttsRepository.shutdown()
    }
}

// Estados de la aplicación
enum class IALiveState {
    IDLE,
    INITIALIZING,
    READY,
    LISTENING,
    PROCESSING_STT,
    PROCESSING_LLM,
    SPEAKING,
    ERROR
}

// Modelo para mensajes de conversación
data class ConversationMessage(
    val text: String,
    val isUser: Boolean,
    val timestamp: Long
)

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun IALiveScreen(
    state: IALiveState,
    displayText: String,
    conversationHistory: List<ConversationMessage>,
    isListening: Boolean,
    isProcessingLLM: Boolean,
    isSpeaking: Boolean,
    onStartListening: () -> Unit,
    onStopListening: () -> Unit,
    onStopAll: () -> Unit,
    onBackClick: () -> Unit,
    onSelectModel: () -> Unit
) {
    val listState = rememberLazyListState()
    
    // Auto-scroll a los mensajes más recientes
    LaunchedEffect(conversationHistory.size) {
        if (conversationHistory.isNotEmpty()) {
            listState.animateScrollToItem(conversationHistory.size - 1)
        }
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .background(
                Brush.verticalGradient(
                    colors = listOf(
                        OrabelPrimary.copy(alpha = 0.1f),
                        OrabelSecondary.copy(alpha = 0.1f),
                        OrabelAccent.copy(alpha = 0.1f)
                    )
                )
            )
    ) {
        // Header
        TopAppBar(
            title = {
                Row(
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(
                        "🤖 IA Live",
                        fontSize = 20.sp,
                        fontWeight = FontWeight.Bold
                    )
                    
                    // Indicadores de estado
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    AnimatedVisibility(visible = isListening) {
                        StatusIndicator("🎤", OrabelPrimary)
                    }
                    
                    AnimatedVisibility(visible = isProcessingLLM) {
                        StatusIndicator("🧠", OrabelSecondary)
                    }
                    
                    AnimatedVisibility(visible = isSpeaking) {
                        StatusIndicator("🔊", OrabelAccent)
                    }
                }
            },
            navigationIcon = {
                IconButton(onClick = onBackClick) {
                    Icon(Icons.Default.ArrowBack, contentDescription = "Volver")
                }
            },
            actions = {
                IconButton(onClick = onSelectModel) {
                    Icon(Icons.Default.Settings, contentDescription = "Configuración")
                }
            }
        )
        
        // Contenido principal
        Box(
            modifier = Modifier
                .weight(1f)
                .padding(16.dp)
        ) {
            if (conversationHistory.isEmpty()) {
                // Pantalla de estado inicial
                StatusScreen(
                    state = state,
                    displayText = displayText
                )
            } else {
                // Historia de conversación
                ConversationScreen(
                    history = conversationHistory,
                    listState = listState,
                    currentDisplayText = displayText
                )
            }
        }
        
        // Control buttons
        ControlButtons(
            state = state,
            onStartListening = onStartListening,
            onStopListening = onStopListening,
            onStopAll = onStopAll
        )
    }
}

@Composable
fun StatusIndicator(icon: String, color: Color) {
    val infiniteTransition = rememberInfiniteTransition(label = "pulse")
    val scale by infiniteTransition.animateFloat(
        initialValue = 0.8f,
        targetValue = 1.2f,
        animationSpec = infiniteRepeatable(
            animation = tween(1000),
            repeatMode = RepeatMode.Reverse
        ),
        label = "scale"
    )
    
    Box(
        modifier = Modifier
            .size(24.dp)
            .scale(scale)
            .background(color.copy(alpha = 0.2f), CircleShape),
        contentAlignment = Alignment.Center
    ) {
        Text(
            text = icon,
            fontSize = 12.sp
        )
    }
}

@Composable
fun StatusScreen(
    state: IALiveState,
    displayText: String
) {
    Column(
        modifier = Modifier.fillMaxSize(),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.Center
    ) {
        // Icono de estado
        val stateIcon = when (state) {
            IALiveState.IDLE -> "💤"
            IALiveState.INITIALIZING -> "⚙️"
            IALiveState.READY -> "✅"
            IALiveState.LISTENING -> "🎤"
            IALiveState.PROCESSING_STT -> "⏳"
            IALiveState.PROCESSING_LLM -> "🧠"
            IALiveState.SPEAKING -> "🔊"
            IALiveState.ERROR -> "❌"
        }
        
        Text(
            text = stateIcon,
            fontSize = 48.sp,
            modifier = Modifier.padding(bottom = 16.dp)
        )
        
        Text(
            text = displayText,
            fontSize = 16.sp,
            textAlign = TextAlign.Center,
            color = MaterialTheme.colorScheme.onBackground,
            modifier = Modifier.padding(horizontal = 24.dp)
        )
    }
}

@Composable
fun ConversationScreen(
    history: List<ConversationMessage>,
    listState: LazyListState,
    currentDisplayText: String
) {
    LazyColumn(
        state = listState,
        modifier = Modifier.fillMaxSize(),
        verticalArrangement = Arrangement.spacedBy(12.dp)
    ) {
        items(history) { message ->
            MessageBubble(message = message)
        }
        
        // Mostrar texto actual si hay procesamiento en curso
        if (currentDisplayText.contains("🧠") || currentDisplayText.contains("🔊")) {
            item {
                Card(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(vertical = 8.dp),
                    colors = CardDefaults.cardColors(
                        containerColor = MaterialTheme.colorScheme.surfaceVariant.copy(alpha = 0.5f)
                    )
                ) {
                    Text(
                        text = currentDisplayText,
                        modifier = Modifier.padding(16.dp),
                        fontSize = 14.sp,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
        }
    }
}

@Composable
fun MessageBubble(message: ConversationMessage) {
    val backgroundColor = if (message.isUser) {
        OrabelPrimary.copy(alpha = 0.1f)
    } else {
        OrabelSecondary.copy(alpha = 0.1f)
    }
    
    val alignment = if (message.isUser) Alignment.CenterEnd else Alignment.CenterStart
    
    Box(
        modifier = Modifier.fillMaxWidth(),
        contentAlignment = alignment
    ) {
        Card(
            modifier = Modifier.widthIn(max = 280.dp),
            shape = RoundedCornerShape(
                topStart = 16.dp,
                topEnd = 16.dp,
                bottomStart = if (message.isUser) 16.dp else 4.dp,
                bottomEnd = if (message.isUser) 4.dp else 16.dp
            ),
            colors = CardDefaults.cardColors(
                containerColor = backgroundColor
            )
        ) {
            Column(
                modifier = Modifier.padding(12.dp)
            ) {
                Text(
                    text = if (message.isUser) "👤 Tú" else "🤖 IA",
                    fontSize = 12.sp,
                    fontWeight = FontWeight.Bold,
                    color = if (message.isUser) OrabelPrimary else OrabelSecondary,
                    modifier = Modifier.padding(bottom = 4.dp)
                )
                
                Text(
                    text = message.text,
                    fontSize = 14.sp,
                    color = MaterialTheme.colorScheme.onBackground
                )
            }
        }
    }
}

@Composable
fun ControlButtons(
    state: IALiveState,
    onStartListening: () -> Unit,
    onStopListening: () -> Unit,
    onStopAll: () -> Unit
) {
    Card(
        modifier = Modifier
            .fillMaxWidth()
            .padding(16.dp),
        elevation = CardDefaults.cardElevation(defaultElevation = 8.dp)
    ) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(16.dp),
            horizontalArrangement = Arrangement.SpaceEvenly
        ) {
            // Botón principal con un solo clic
            when (state) {
                IALiveState.READY -> {
                    FloatingActionButton(
                        onClick = onStartListening,
                        modifier = Modifier.size(64.dp),
                        containerColor = OrabelPrimary
                    ) {
                        Icon(
                            Icons.Default.Mic,
                            contentDescription = "Iniciar grabación",
                            modifier = Modifier.size(32.dp),
                            tint = Color.White
                        )
                    }
                }
                
                IALiveState.LISTENING -> {
                    FloatingActionButton(
                        onClick = onStopListening,
                        modifier = Modifier.size(64.dp),
                        containerColor = OrabelAccent
                    ) {
                        Icon(
                            Icons.Default.Stop,
                            contentDescription = "Parar grabación",
                            modifier = Modifier.size(32.dp),
                            tint = Color.White
                        )
                    }
                }
                
                IALiveState.PROCESSING_STT, IALiveState.PROCESSING_LLM, IALiveState.SPEAKING -> {
                    FloatingActionButton(
                        onClick = onStopAll,
                        modifier = Modifier.size(64.dp),
                        containerColor = OrabelAccent
                    ) {
                        Icon(
                            Icons.Default.Stop,
                            contentDescription = "Detener todo",
                            modifier = Modifier.size(32.dp),
                            tint = Color.White
                        )
                    }
                }
                
                else -> {
                    // Estados como INITIALIZING, ERROR
                    FloatingActionButton(
                        onClick = { /* No action */ },
                        modifier = Modifier.size(64.dp),
                        containerColor = Color.Gray
                    ) {
                        Icon(
                            Icons.Default.Mic,
                            contentDescription = "No disponible",
                            modifier = Modifier.size(32.dp),
                            tint = Color.White
                        )
                    }
                }
            }
        }
    }
}

// Estados de la aplicación
enum class IALiveState {
    IDLE,
    INITIALIZING,
    READY,
    LISTENING,
    PROCESSING_STT,
    PROCESSING_LLM,
    SPEAKING,
    RECORDING,
    ERROR
}
