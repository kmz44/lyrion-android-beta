<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="auto">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" android:minSdkVersion="33"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" android:minSdkVersion="33"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="33"/>
    <!-- Permisos adicionales para Android 11+ -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <application
        android:name=".OrabelApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OrabelAndroid"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="false"
        android:extractNativeLibs="true"
        android:allowNativeHeapPointerTagging="false"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="31">
        <!-- Servicio de motor TTS (Sherpa ONNX) integrado -->
        <service
            android:name="com.k2fsa.sherpa.onnx.tts.engine.TtsService"
            android:enabled="true"
            android:exported="true"
            android:label="@string/sherpa_tts_engine_name">
            <intent-filter>
                <action android:name="android.intent.action.TTS_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <!-- Actividades auxiliares del motor TTS (usarán tema de Lyrion) -->
        <activity
            android:name="com.k2fsa.sherpa.onnx.tts.engine.MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.OrabelAndroid">
            <!-- Permite que el sistema abra configuración del motor -->
            <intent-filter>
                <action android:name="android.speech.tts.engine.CONFIGURE_ENGINE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.k2fsa.sherpa.onnx.tts.engine.ManageLanguagesActivity"
            android:exported="false"
            android:theme="@style/Theme.OrabelAndroid" />
        <activity
            android:name="com.k2fsa.sherpa.onnx.tts.engine.GetSampleText"
            android:exported="true"
            android:theme="@style/Theme.OrabelAndroid">
            <intent-filter>
                <action android:name="android.speech.tts.engine.GET_SAMPLE_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.k2fsa.sherpa.onnx.tts.engine.CheckVoiceData"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.k2fsa.sherpa.onnx.tts.engine.InstallVoiceData"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.tts.engine.INSTALL_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.OrabelAndroid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- LoginActivity con deeplink para callback de Supabase OAuth -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.OrabelAndroid">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="lyrion"
                    android:host="auth-callback" />
            </intent-filter>
        </activity>
        
        <activity android:name=".ui.screens.welcome.WelcomeActivity" android:exported="false"/>
        <activity android:name=".ui.screens.main.ModernMainActivity" android:exported="false"/>
        <activity android:name=".ui.screens.model_setup.ModernModelSetupActivity" android:exported="false"/>
        <activity android:name=".ui.screens.model_setup.LightweightModelSetupActivity" android:exported="false"/>
        <activity android:name=".ui.screens.chat.ChatActivity" android:exported="false"/>
        <activity android:name=".ui.screens.settings.SettingsActivity" android:exported="false"/>
        <activity android:name=".ui.screens.first_setup.FirstSetupActivity" android:exported="false"/>
        <activity android:name=".ui.screens.translation.TranslationActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.tts.TtsActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.stt.SttActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.whisper_stt.WhisperSttActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="Whisper STT"/>
        <activity android:name=".ui.screens.realtime_translator.RealtimeTranslatorActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="Traductor en Tiempo Real"/>
        <activity android:name=".ui.screens.whisper_download.WhisperDownloadActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="Descarga de Modelos Whisper"/>
        <activity android:name=".ui.screens.ocr.OcrActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.ialive.IALiveActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.offlineoptions.OfflineOptionsActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.calendar.CalendarActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.search.SearchActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.profile.ProfileActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.profile.MedicalProfileActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.health.HealthDiaryActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".health.HealthReportShareActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>
        <activity android:name=".ui.screens.study.StudyKnowledgeActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.OrabelAndroid"/>
        <activity android:name=".ui.screens.personal.PersonalContextActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.OrabelAndroid"/>
        <activity android:name=".ui.screens.gemini_live.GeminiLiveActivity" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.OrabelAndroid"
            android:label="Gemini Live Audio"/>

        
        <!-- Servicio de asistente de voz en background (con pantalla bloqueada) -->
        <service
            android:name=".services.VoiceAssistantService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone">
        </service>
        
        <!-- Servicio en primer plano requerido para MediaProjection en Android 14+ -->
    <!-- Eliminado servicio de proyección de Gemini Live -->
        <activity 
            android:name=".ui.screens.webview.WebViewActivity"
            android:theme="@style/Theme.OrabelAndroid"
            android:exported="false" />
        
        <!-- FileProvider para la cámara -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
