<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- Opción: Seleccionar modelo (.tflite) -->
    <LinearLayout
        android:id="@+id/btn_pick_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/button_filled_primary"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:tint="@color/text_on_primary"
            android:src="@drawable/ic_camera_white_24dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seleccionar modelo (.tflite)"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Importa un modelo TFLite desde archivos"
                android:textColor="@color/text_on_primary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Opción: Seleccionar etiquetas (.txt) -->
    <LinearLayout
        android:id="@+id/btn_pick_labels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_filled_primary"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:tint="@color/text_on_primary"
            android:src="@drawable/ic_camera_white_24dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seleccionar etiquetas (.txt)"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Importa la lista de etiquetas para el modelo"
                android:textColor="@color/text_on_primary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Opción: Usar modelo integrado -->
    <LinearLayout
        android:id="@+id/btn_use_builtin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_outlined_secondary"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:tint="@color/brand_accent"
            android:src="@android:drawable/ic_menu_info_details" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usar modelo integrado"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empieza con el modelo incluido en la app"
                android:textColor="@color/text_primary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Opción: Catálogo de modelos (descargar) -->
    <LinearLayout
        android:id="@+id/btn_catalog_models"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_filled_primary"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:tint="@color/text_on_primary"
            android:src="@android:drawable/stat_sys_download" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catálogo de modelos (descargar)"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explora y descarga modelos compatibles"
                android:textColor="@color/text_on_primary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Opción: Acerca de -->
    <LinearLayout
        android:id="@+id/btn_about"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_outlined_secondary"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:tint="@color/brand_accent"
            android:src="@android:drawable/ic_menu_help" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acerca de y compatibilidad"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información técnica y licencias"
                android:textColor="@color/text_primary"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="20sp"
        android:layout_marginTop="24dp" />

    <ProgressBar
        android:id="@+id/progressBar3"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="2000"
        android:progressTint="@color/brand_accent" />

    <TextView
        android:id="@+id/progressBar_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/2000 kcal"
        android:layout_marginTop="4dp" />

    <TableLayout
        android:id="@+id/tablelayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:stretchColumns="0,1,2" />

</LinearLayout>
